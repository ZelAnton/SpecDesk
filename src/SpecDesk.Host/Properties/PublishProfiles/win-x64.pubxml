<?xml version="1.0" encoding="utf-8"?>
<!--
  Single-file, self-contained Windows x64 release. Produces ONE shareable SpecDesk.Host.exe under
  bin/Release/net10.0/win-x64/publish/ that runs on a machine without the .NET runtime installed.

      dotnet publish src/SpecDesk.Host -p:PublishProfile=win-x64 -p:DebugType=none

  (`-p:DebugType=none` is a global property — it also suppresses the referenced projects' .pdb
  symbol files, so the publish folder ends up containing just the one exe. Omit it if you want the
  symbols; the .exe alone is always enough to run.)

  Notes:
  - Self-contained → no .NET install needed on the target; the exe is large (compression is on).
  - The native bits (Photino, LibGit2Sharp) and all content (wwwroot/, samples/) are bundled and
    self-extracted at startup; the app loads them from AppContext.BaseDirectory (see Program.cs).
  - The target machine still needs the Microsoft Edge WebView2 Runtime (pre-installed on Windows 11
    and most up-to-date Windows 10). https://developer.microsoft.com/microsoft-edge/webview2/
  - Trimming is intentionally OFF — Photino/LibGit2Sharp/reflection do not trim safely.
  - Publishing runs the webview esbuild bundle, so node/npm must be available on the build machine.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
