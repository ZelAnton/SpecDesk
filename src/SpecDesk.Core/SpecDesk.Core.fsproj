<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
	</PropertyGroup>

	<!-- F# compile order is significant — list files in dependency order. -->
	<ItemGroup>
		<Compile Include="Placeholder.fs" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SpecDesk.Contracts\SpecDesk.Contracts.csproj" />
	</ItemGroup>

	<ItemGroup>
		<!-- Explicit FSharp.Core required under Central Package Management. -->
		<PackageReference Include="FSharp.Core" />
	</ItemGroup>

</Project>
